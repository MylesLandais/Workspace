      "source": [
        "## 6. ML Pipeline Example: Face Detection\n",
        "\n",
        "Example pipeline for detecting faces in images using the embedded image data.\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# Example: Face detection pipeline (requires opencv-python)\n",
        "def detect_faces_in_dataset(df, sample_size=100):\n",
        "    \"\"\"\",
        "    Example face detection pipeline.\n",
        "    \n",
        "    Note: Requires opencv-python installed\n",
        "    \"\"\"\n",
        "    try:\n",
        "        import cv2\n",
        "    except ImportError:\n",
        "        print(\"Install opencv-python first: pip install opencv-python\")\n",
        "        return None\n",
        "    \n",
        "    # Load face detector (requires cascade file)\n",
        "    face_cascade = cv2.CascadeClassifier(\n",
        "        cv2.data.haarcascades + 'haarcascade_frontalface_default.xml'\n",
        "    )\n",
        "    \n",
        "    results = []\n",
        "    sample = df[df['image_bytes'].notna()].sample(min(sample_size, len(df)))\n",
        "    \n",
        "    for _, row in sample.iterrows():\n",
        "        try:\n",
        "            img_bytes = row['image_bytes']\n",
        "            img = cv2.imdecode(np.frombuffer(img_bytes, np.uint8), cv2.IMREAD_COLOR)\n",
        "            \n",
        "            if img is None:\n",
        "                continue\n",
        "            \n",
        "            gray = cv2.cvtColor(img, cv2.COLOR_BGR2GRAY)\n",
        "            faces = face_cascade.detectMultiScale(gray, 1.1, 4)\n",
        "            \n",
        "            results.append({\n",
        "                'id': row['id'],\n",
        "                'thread_id': row['thread_id'],\n",
        "                'faces_detected': len(faces),\n",
        "                'has_face': len(faces) > 0\n",
        "            })\n",
        "        except Exception as e:\n",
        "            continue\n",
        "    \n",
        "    results_df = pd.DataFrame(results)\n",
        "    print(f\"Scanned {len(results_df)} images\")\n",
        "    print(f\"Images with faces: {results_df['has_face'].sum()}\")\n",
        "    return results_df\n",
        "\n",
        "# Run face detection on a sample\n",
        "# results = detect_faces_in_dataset(df, sample_size=50)\n",
        "# if results is not None:\n",
        "#     display(results['has_face'].value_counts())\n",
        "\n",
        "print(\"Face detection function ready.\")\n",
        "print(\"Uncomment the code above to run on a sample of images.\")\n"
      ]
    },
