      "source": [
        "## 7. Exporting Subsets\n",
        "\n",
        "Create filtered datasets for specific use cases.\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# Export filtered subsets\n",
        "def export_subset(df, filters=None, output_path=None, embed_images=True):\n",
        "    \"\"\"\",
        "    Export a filtered subset of the dataset.\n",
        "    \n",
        "    Args:\n",
        "        df: Source dataframe\n",
        "        filters: Dict of column -> value conditions\n",
        "        output_path: Path for output parquet\n",
        "        embed_images: Whether to include image bytes\n",
        "    \"\"\"\n",
        "    subset = df.copy()\n",
        "    \n",
        "    # Apply filters\n",
        "    if filters:\n",
        "        for col, val in filters.items():\n",
        "            if callable(val):\n",
        "                subset = subset[subset[col].apply(val)]\n",
        "            else:\n",
        "                subset = subset[subset[col] == val]\n",
        "    \n",
        "    # Remove image bytes if not needed\n",
        "    if not embed_images:\n",
        "        subset['image_bytes'] = None\n",
        "    \n",
        "    if output_path:\n",
        "        subset.to_parquet(output_path, index=False)\n",
        "        print(f\"Exported {len(subset)} posts to {output_path}\")\n",
        "        print(f\"  Size: {Path(output_path).stat().st_size / (1024**2):.1f} MB\")\n",
        "    \n",
        "    return subset\n",
        "\n",
        "# Example exports (commented out)\n",
        "\n",
        "# Export only posts from /b/ board without images (metadata only)\n",
