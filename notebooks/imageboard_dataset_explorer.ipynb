        "## 2. Image Viewing & Manipulation\n",
        "\n",
        "Access and display images directly from the parquet file.\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# Helper function to display images\n",
        "def display_image_from_row(row, figsize=(8, 6)):\n",
        "    \"\"\"Display an image from a dataframe row.\"\"\"\n",
        "    if pd.isna(row['image_bytes']):\n",
        "        print(\"No image in this post\")\n",
        "        return None\n",
        "    \n",
        "    img = Image.open(io.BytesIO(row['image_bytes']))\n",
        "    plt.figure(figsize=figsize)\n",
        "    plt.imshow(img)\n",
        "    plt.title(f\"Post: {row['id']}\\nSubject: {row['subject'][:50]}\")\n",
        "    plt.axis('off')\n",
        "    plt.show()\n",
        "    return img\n",
        "\n",
        "# Display a random post with image\n",
        "if PARQUET_FILE:\n",
        "    posts_with_images = df[df['image_bytes'].notna()]\n",
        "    sample = posts_with_images.sample(1).iloc[0]\n",
        "    \n",
        "    print(f\"Sample Post: {sample['id']}\")\n",
        "    print(f\"Thread: /{sample['board']}/{sample['thread_id']}\")\n",
        "    print(f\"Comment: {sample['text'][:200]}...\")\n",
        "    print()\n",
        "    \n",
        "    _ = display_image_from_row(sample)\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# Grid display of multiple images\n",
        "def display_image_grid(df_subset, cols=4, figsize=(15, 10)):\n",
        "    \"\"\"Display a grid of images from a dataframe subset.\"\"\"\n",
        "    n = min(len(df_subset), cols * 3)  # Max 12 images\n",
        "    rows = (n + cols - 1) // cols\n",
        "    \n",
        "    fig, axes = plt.subplots(rows, cols, figsize=figsize)\n",
        "    axes = axes.flatten() if rows > 1 else [axes] if cols == 1 else axes.flatten()\n",
        "    \n",
        "    for i, (_, row) in enumerate(df_subset.head(n).iterrows()):\n",
        "        if pd.isna(row['image_bytes']):\n",
        "            axes[i].text(0.5, 0.5, 'No Image', ha='center', va='center')\n",
        "            axes[i].axis('off')\n",
        "            continue\n",
        "        \n",
        "        img = Image.open(io.BytesIO(row['image_bytes']))\n",
        "        axes[i].imshow(img)\n",
        "        axes[i].set_title(f\"{row['board']}/{row['thread_id']}\", fontsize=8)\n",
        "        axes[i].axis('off')\n",
        "    \n",
        "    # Hide unused axes\n",
        "    for j in range(i + 1, len(axes)):\n",
        "        axes[j].axis('off')\n",
        "    \n",
        "    plt.tight_layout()\n",
        "    plt.show()\n",
        "\n",
        "# Display sample images\n",
        "if PARQUET_FILE:\n",
        "    print(\"Sample Images from Recent Threads:\")\n",
        "    display_image_grid(df[df['image_bytes'].notna()].sample(12))\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# Extract and save images to disk\n",
        "def extract_images_to_folder(df, output_dir, max_images=None):\n",
        "    \"\"\"Extract images from dataframe to a folder.\"\"\"\n",
        "    output_dir = Path(output_dir)\n",
        "    output_dir.mkdir(parents=True, exist_ok=True)\n",
        "    \n",
        "    count = 0\n",
        "    for _, row in df.iterrows():\n",
        "        if pd.isna(row['image_bytes']):\n",
        "            continue\n",
        "        \n",
        "        ext = row.get('image_ext', '.jpg')\n",
        "        if not ext.startswith('.'):\n",
        "            ext = '.jpg'\n",
        "        \n",
        "        filename = f\"{row['id']}{ext}\"\n",
        "        filepath = output_dir / filename\n",
        "        \n",
        "        with open(filepath, 'wb') as f:\n",
        "            f.write(row['image_bytes'])\n",
        "        \n",
        "        count += 1\n",
        "        if max_images and count >= max_images:\n",
        "            break\n",
        "    \n",
        "    print(f\"Extracted {count} images to {output_dir}\")\n",
        "    return count\n",
        "\n",
        "# Example usage (commented out to avoid accidental extraction)\n",
        "# extract_images_to_folder(df.head(100), './extracted_images', max_images=10)\n",
        "print(\"Helper function ready. Use: extract_images_to_folder(df, 'output_dir')\")\n"
      ]
    },
    {
