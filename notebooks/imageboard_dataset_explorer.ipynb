        "## 3. Text Analysis & Search\n",
        "\n",
        "Search and analyze post content.\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# Search posts by keyword\n",
        "def search_posts(df, keyword, case_sensitive=False):\n",
        "    \"\"\"Search posts containing a keyword.\"\"\"\n",
        "    if case_sensitive:\n",
        "        mask = df['text'].str.contains(keyword, na=False)\n",
        "    else:\n",
        "        mask = df['text'].str.contains(keyword, case=False, na=False)\n",
        "    return df[mask]\n",
        "\n",
        "# Example: Search for posts mentioning specific topics\n",
        "if PARQUET_FILE:\n",
        "    print(\"Search Examples:\")\n",
        "    \n",
        "    # Search for posts about \"built\"\n",
        "    built_posts = search_posts(df, 'built')\n",
        "    print(f\"  Posts mentioning 'built': {len(built_posts)}\")\n",
        "    \n",
        "    # Search for posts about \"irl\" (in real life)\n",
        "    irl_posts = search_posts(df, 'irl')\n",
        "    print(f\"  Posts mentioning 'irl': {len(irl_posts)}\")\n",
        "    \n",
        "    # Search for posts about feet\n",
        "    feet_posts = search_posts(df, 'feet')\n",
        "    print(f\"  Posts mentioning 'feet': {len(feet_posts)}\")\n",
        "\n",
        "    # Show sample matches\n",
        "    print(\"\\nSample 'irl' posts:\")\n",
        "    for _, row in irl_posts.head(3).iterrows():\n",
        "        text = row['text'][:100] if pd.notna(row['text']) else '[no text]'\n",
        "        print(f\"  [{row['id']}] {text}...\")\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# Text analysis - word frequency\n",
        "from collections import Counter\n",
        "import re\n",
        "\n",
        "def get_word_frequency(df, min_length=3, top_n=30):\n",
        "    \"\"\"Get most common words in post text.\"\"\"\n",
        "    all_words = []\n",
        "    for text in df['text'].dropna():\n",
        "        words = re.findall(r'\\b[a-zA-Z]{' + str(min_length) + ',}\\b', text.lower())\n",
        "        all_words.extend(words)\n",
        "    return Counter(all_words).most_common(top_n)\n",
        "\n",
        "if PARQUET_FILE:\n",
        "    print(\"Top 30 Words in Posts:\")\n",
        "    word_freq = get_word_frequency(df)\n",
        "    for word, count in word_freq:\n",
        "        print(f\"  {word:20} {count:>5}\")\n"
      ]
    },
