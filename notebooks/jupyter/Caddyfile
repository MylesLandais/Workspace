# Caddy reverse proxy configuration for jupyter.dev.local services
# All services accessible via .dev.local hostnames on port 80

jupyter.dev.local {
    reverse_proxy jupyterlab:8888
}

s3.jupyter.dev.local {
    reverse_proxy minio:9001
}

# S3 API endpoint on port 9000
s3-api.jupyter.dev.local {
    reverse_proxy minio:9000
}

n4j.jupyter.dev.local {
    reverse_proxy neo4j:7474
}

cache.jupyter.dev.local {
    respond "Valkey/Redis available at cache.jupyter.dev.local:6379 (TCP)" 200
}
