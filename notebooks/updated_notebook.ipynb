   "source": [
    "## Helper Functions\n",
    "\n",
    "Utilities for displaying images and testing the tool directly."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "define-helpers",
   "metadata": {},
   "outputs": [],
   "source": [
    "import base64\n",
    "from IPython.display import Image, display\n",
    "\n",
    "\n",
    "def display_generated_image(result: Dict) -> None:\n",
    "    \"\"\"Display a generated image from base64 data.\"\"\"\n",
    "    if result['status'] != 'success':\n",
    "        print(f\"Cannot display image: {result['message']}\")\n",
    "        if 'error' in result:\n",
    "            print(f\"Error: {result['error']}\")\n",
    "        return\n",
    "    \n",
    "    try:\n",
    "        image_bytes = base64.b64decode(result['image_data'])\n",
    "        print(f\"\\nSeed: {result['seed']}\")\n",
    "        print(f\"Prompt: {result['prompt']}\")\n",
    "        print(f\"Filename: {result['filename']}\\n\")\n",
    "        display(Image(image_bytes))\n",
    "    except Exception as e:\n",
    "        print(f\"Error displaying image: {e}\")\n",
    "\n",
    "\n",
    "def simple_test(\n",
    "    prompt: str = \"a cute robot cat, digital art\",\n",
    "    width: int = 1024,\n",
    "    height: int = 1024,\n",
    "    steps: int = 4,\n",
    "    seed: Optional[int] = 12345\n",
    ") -> Dict:\n",
    "    \"\"\"Quick test of the image generation tool without using the agent.\n",
    "    \n",
    "    Args:\n",
    "        prompt: Text description of the image\n",
    "        width: Image width in pixels\n",
    "        height: Image height in pixels\n",
    "        steps: Number of generation steps\n",
    "        seed: Random seed for reproducibility\n",
    "    \n",
    "    Returns:\n",
    "        Result dictionary from generate_image_with_runpod\n",
    "    \"\"\"\n",
    "    print(\"=\" * 70)\n",
    "    print(\"Direct RunPod API Test (No Agent)\")\n",
    "    print(\"=\" * 70)\n",
    "    print(f\"\\nPrompt: {prompt}\")\n",
    "    print(f\"Dimensions: {width}x{height}\")\n",
    "    print(f\"Steps: {steps}, Seed: {seed}\")\n",
    "    print(f\"\\nExpected runtime: 30-60 seconds\\n\")\n",
    "    \n",
    "    result = generate_image_with_runpod(\n",
    "        prompt=prompt,\n",
    "        width=width,\n",
    "        height=height,\n",
    "        steps=steps,\n",
    "        seed=seed\n",
    "    )\n",
    "    \n",
    "    print(f\"\\nStatus: {result['status']}\")\n",
    "    print(f\"Message: {result['message']}\")\n",
    "    \n",
    "    if result['status'] == 'success':\n",
    "        display_generated_image(result)\n",
    "    \n",
    "    return result\n",
    "\n",
    "\n",
    "print(\"✓ Helper functions defined\")"
   ]
  },
