{
  "name": "media-platform",
  "version": "1.0.0",
  "description": "Media platform with Neo4j, Valkey cache, and S3-compatible storage",
  "main": "app.js",
  "scripts": {
    "dev": "ENVIRONMENT=local nodemon app.js",
    "staging": "ENVIRONMENT=staging node app.js",
    "production": "ENVIRONMENT=production node app.js",
    "setup": "bash scripts/setup-dev.sh",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "health": "node scripts/health-check.js",
    "cache:flush": "node scripts/cache-admin.js flush",
    "cache:stats": "node scripts/cache-admin.js stats",
    "test": "jest",
    "test:integration": "jest --testPathPattern=integration"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.400.0",
    "@aws-sdk/s3-request-presigner": "^3.400.0",
    "express": "^4.18.0",
    "neo4j-driver": "^5.14.0",
    "redis": "^4.6.0",
    "dotenv": "^16.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.0",
    "jest": "^29.0.0"
  },
  "keywords": [
    "media",
    "neo4j",
    "valkey",
    "s3",
    "cache"
  ],
  "author": "",
  "license": "ISC"
}

