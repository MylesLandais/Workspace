{
  "repository": {},
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "bun run build.ts",
    "watch": "bun run build.ts --watch",
    "typecheck": "tsc --noEmit",
    "codegen": "graphql-codegen --config codegen.ts",
