# =============================================================================
# CENTRALIZED ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your actual values
# This file consolidates all environment variables used across the project

# =============================================================================
# AI API KEYS
# =============================================================================

# OpenRouter API Key (Get from https://openrouter.ai/keys)
# Used for: AI model access, tool use, image analysis
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Claude API Token (Anthropic)
# Used for: Direct Claude API access
CLAUDE_API_TOKEN=your_claude_api_token_here

# =============================================================================
# CLOUD INFRASTRUCTURE
# =============================================================================

# RunPod API Key (Get from https://runpod.io)
# Used for: GPU instance management, model deployment
RUNPOD_API_KEY=your_runpod_api_key_here

# RunPod Network Volume ID (optional)
# Used for: Persistent storage across instances
RUNPOD_NETWORK_VOLUME_ID=your_volume_id_here

# =============================================================================
# DATA & RESEARCH APIs
# =============================================================================

# Finnhub API Key (Get from https://finnhub.io)
# Used for: Financial data and stock market analysis
FINNHUB_API_KEY=your_finnhub_api_key_here

# Tavily API Key (Get from https://tavily.com)
# Used for: Web search and research
TAVILY_API_KEY=your_tavily_api_key_here

# =============================================================================
# HUGGING FACE CONFIGURATION
# =============================================================================

# Hugging Face Token (Get from https://huggingface.co/settings/tokens)
# Used for: Model downloads, dataset uploads, private repos
HF_TOKEN=your_hugging_face_token_here

# Hugging Face Username
# Used for: Dataset uploads and model sharing
HF_USERNAME=your_hf_username_here

# Default dataset name for uploads
DATASET_NAME=my-image-dataset

# =============================================================================
# DISCORD BOT (if applicable)
# =============================================================================

# Discord Bot Token (Get from https://discord.com/developers/applications)
# Used for: Discord bot functionality
DISCORD_TOKEN=your_discord_bot_token_here

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# PostgreSQL Configuration (for development)
POSTGRES_DB=vector_demo
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_HOST=postgres-vector
POSTGRES_PORT=5432

# Neo4j Graph Database (Bunny backend)
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password
NEO4J_DATABASE=neo4j

# PostgreSQL (Task Scheduler Database)
# Used for: Scheduled tasks, task runs, nix environments
POSTGRES_URL=postgresql://scheduler:localpassword@localhost:5432/feed_scheduler
POSTGRES_USER=scheduler
POSTGRES_PASSWORD=localpassword

# =============================================================================
# TASK SCHEDULER CONFIGURATION (Celery + RedBeat)
# =============================================================================

# Celery Broker (Redis/Valkey)
# Used for: Task queue, message passing between beat and workers
CELERY_BROKER_URL=redis://localhost:6379/0

# Celery Result Backend (Redis/Valkey)
# Used for: Storing task execution results
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Task Scheduler Settings
TASK_SCHEDULER_TIMEZONE=UTC
NIX_STORE_PATH=/nix/store

# =============================================================================
# BUNNY GRAPHQL API CONFIGURATION
# =============================================================================

# Bunny GraphQL API endpoint
# Used for: Feed data, source management, identity profiles
# Start Bunny server: cd ~/Workspace/Bunny/app/server && bun run dev
VITE_GRAPHQL_API=http://localhost:4002/api/graphql

# Valkey/Redis Cache (for Bunny)
VALKEY_URI=redis://localhost:6379
VALKEY_PASSWORD=

# MinIO/S3 Object Storage (for cached images)
# Images are stored with presigned URLs that expire after 4 hours
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=model-images
MINIO_SECURE=false

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================

# Environment (development, staging, production)
ENVIRONMENT=development

# Debug mode (true/false)
DEBUG=true

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO