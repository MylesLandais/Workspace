# Use the official Bun image
FROM oven/bun:1.1-slim

WORKDIR /app

# Copy package files
COPY package.json bun.lock* ./

# Install dependencies using Bun
RUN bun install

# Copy application code
COPY . .

# Expose the Astro port
EXPOSE 4321

# Start the application with Bun
CMD ["bun", "run", "dev", "--host"]
