{
  "name": "feed-manager-client",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "bun run dev",
    "dev:node": "astro dev",
    "start": "bun run dev",
    "start:node": "astro dev",
    "build": "bun run build",
    "build:node": "astro build",
    "preview": "bun run preview",
    "preview:node": "astro preview",
    "astro": "astro",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:watch": "vitest --watch",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:docker": "docker exec frontend-frontend-1 npm run test:e2e",
    "test:all": "bun run test && bun run test:e2e",
    "generate-mock-data": "tsx scripts/generate-graphql-mock-data.ts",
    "generate-mock-data:small": "tsx scripts/generate-graphql-mock-data.ts --size=small",
    "generate-mock-data:medium": "tsx scripts/generate-graphql-mock-data.ts --size=medium",
    "generate-mock-data:large": "tsx scripts/generate-graphql-mock-data.ts --size=large",
    "docker:up": "docker-compose -f docker-compose.yml up -d",
    "docker:down": "docker-compose -f docker-compose.yml down",
    "docker:logs": "docker-compose -f docker-compose.yml logs -f",
    "docker:build": "docker-compose -f docker-compose.yml build",
    "docker:rebuild": "docker-compose -f docker-compose.yml up -d --build"
  },
  "dependencies": {
    "@apollo/client": "^3.11.0",
    "@google/genai": "^1.34.0",
    "astro": "^4.15.0",
    "graphql": "^16.9.0",
    "lucide-react": "^0.562.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "recharts": "^3.6.0"
  },
  "devDependencies": {
    "@astrojs/react": "^3.6.0",
    "@astrojs/tailwind": "^5.1.4",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "jsdom": "^23.0.1",
    "msw": "^2.3.0",
    "@playwright/test": "^1.40.0",
    "tailwindcss": "^3.4.13",
    "tsx": "^4.7.0",
    "typescript": "^5.6.2",
    "vitest": "^1.1.3"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}