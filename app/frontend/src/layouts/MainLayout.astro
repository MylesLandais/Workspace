---
import '../styles/global.css';
import ThemeProviderWrapper from '../components/layout/ThemeProviderWrapper';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en" data-theme="kanagawa-dragon">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Feed Manager - Control Plane for Content Ingestion" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <script is:inline>
      // Set initial theme CSS variables before React loads to prevent flash of unstyled content
      (function() {
        const THEME_STORAGE_KEY = 'app-theme';
        const defaultTheme = 'kanagawa-dragon';
        
        // Kanagawa Dragon theme colors
        const kanagawaDragon = {
          '--theme-bg-primary': '#181616',
          '--theme-bg-secondary': '#1F1F1F',
          '--theme-border-primary': '#2A2A2A',
          '--theme-text-primary': '#DCD7BA',
          '--theme-text-secondary': '#727169',
          '--theme-accent-primary': '#98BB6C',
          '--theme-accent-secondary': '#2D4F67',
          '--theme-accent-tertiary': '#7FB4CA',
          '--theme-accent-alert': '#E46876',
          '--theme-scrollbar-track': '#181616',
          '--theme-scrollbar-thumb': '#2D4F67',
          '--theme-scrollbar-thumb-hover': '#98BB6C',
        };
        
        // Default theme colors (gray)
        const defaultThemeColors = {
          '--theme-bg-primary': '#0a0a0a',
          '--theme-bg-secondary': '#111827',
          '--theme-border-primary': '#1f2937',
          '--theme-text-primary': '#f3f4f6',
          '--theme-text-secondary': '#9ca3af',
          '--theme-accent-primary': '#3b82f6',
          '--theme-accent-secondary': '#60a5fa',
          '--theme-accent-tertiary': '#93c5fd',
          '--theme-accent-alert': '#ef4444',
          '--theme-scrollbar-track': '#0a0a0a',
          '--theme-scrollbar-thumb': '#374151',
          '--theme-scrollbar-thumb-hover': '#4b5563',
        };
        
        const storedTheme = localStorage.getItem(THEME_STORAGE_KEY) || defaultTheme;
        const themeColors = storedTheme === 'kanagawa-dragon' ? kanagawaDragon : defaultThemeColors;
        
        const root = document.documentElement;
        root.setAttribute('data-theme', storedTheme);
        
        Object.entries(themeColors).forEach(([key, value]) => {
          root.style.setProperty(key, value);
        });
      })();
    </script>
  </head>
  <body>
    <ThemeProviderWrapper client:load>
      <main class="min-h-screen">
        <slot />
      </main>
    </ThemeProviderWrapper>
  </body>
</html>

