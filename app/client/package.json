{
  "name": "bunny-client",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "NEXT_PUBLIC_USE_MOCK_DATA=true next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "bun test",
    "test:ci": "bun test && rm -rf .next",
    "test:e2e": "playwright test",
    "codegen": "graphql-codegen --config ../codegen.yml",
    "codegen:watch": "graphql-codegen --config ../codegen.yml --watch",
    "db:generate": "drizzle-kit generate --config=drizzle.config.mysql.ts",
    "db:push": "drizzle-kit push --config=drizzle.config.mysql.ts",
    "db:studio": "drizzle-kit studio --config=drizzle.config.mysql.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.958.0",
    "@aws-sdk/s3-request-presigner": "^3.958.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.208.0",
    "@opentelemetry/instrumentation": "^0.208.0",
    "@opentelemetry/instrumentation-fetch": "^0.208.0",
    "@opentelemetry/instrumentation-http": "^0.208.0",
    "@opentelemetry/resources": "^2.2.0",
    "@opentelemetry/sdk-trace-node": "^2.2.0",
    "@opentelemetry/semantic-conventions": "^1.38.0",
    "better-auth": "^1.4.10",
    "better-sqlite3": "^1.1.3",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "framer-motion": "^12.23.26",
    "ioredis": "^5.8.2",
    "lucide-react": "^0.468.0",
    "mysql2": "^3.16.0",
    "next": "15.1.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.4.0",
    "uuid": "^9.0.1",
    "yet-another-react-lightbox": "^3.28.0",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.10",
    "@playwright/test": "^1.57.0",
    "@types/bun": "^1.3.5",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.31.8",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.3",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  }
}