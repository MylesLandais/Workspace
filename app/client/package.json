{
  "name": "bunny-client",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "collab:server": "node server/yjs-server.cjs",
    "dev:collab": "concurrently \"bun run dev\" \"bun run collab:server\"",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "test": "bun test tests/ src/",
    "test:ci": "bun test tests/ src/ && rm -rf .next",
    "test:e2e": "playwright test",
    "codegen": "graphql-codegen --config ../../codegen.yml",
    "codegen:watch": "graphql-codegen --config ../../codegen.yml --watch",
    "db:generate": "drizzle-kit generate --config=drizzle.config.mysql.ts",
    "db:push": "drizzle-kit push --config=drizzle.config.mysql.ts",
    "db:studio": "drizzle-kit studio --config=drizzle.config.mysql.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.958.0",
    "@aws-sdk/s3-request-presigner": "^3.958.0",
    "@google/genai": "1.3.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.208.0",
    "@opentelemetry/instrumentation": "^0.208.0",
    "@opentelemetry/instrumentation-fetch": "^0.208.0",
    "@opentelemetry/instrumentation-http": "^0.208.0",
    "@opentelemetry/resources": "^2.2.0",
    "@opentelemetry/sdk-node": "^0.208.0",
    "@opentelemetry/sdk-trace-node": "^2.2.0",
    "@opentelemetry/semantic-conventions": "^1.38.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@sentry/nextjs": "^10.34.0",
    "@upyo/core": "^0.4.0",
    "@upyo/mock": "^0.4.0",
    "@upyo/smtp": "^0.4.0",
    "better-auth": "^1.4.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "framer-motion": "^12.23.26",
    "ioredis": "^5.8.2",
    "lib0": "^0.2.117",
    "lucide-react": "^0.468.0",
    "mermaid": "^11.12.2",
    "mysql2": "^3.16.0",
    "next": "15.1.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-grid-layout": "1.5.0",
    "react-sketch-canvas": "^6.2.0",
    "recharts": "2.15.0",
    "tailwind-merge": "^3.4.0",
    "uuid": "^9.0.1",
    "ws": "^8.19.0",
    "y-protocols": "^1.0.7",
    "y-websocket": "^3.0.0",
    "yet-another-react-lightbox": "^3.28.0",
    "yjs": "^13.6.29",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.10",
    "@playwright/test": "^1.57.0",
    "@types/bun": "^1.3.5",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "@types/ws": "^8.5.13",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.0",
    "drizzle-kit": "^0.31.8",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.3",
    "lighthouse": "^13.0.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  }
}
